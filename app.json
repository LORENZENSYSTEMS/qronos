{
  "expo": {
    "name": "Qronos",
    "slug": "qronos",
    "version": "1.1.7",
    "orientation": "portrait",
    "icon": "./assets/images/ICONONewQronnos.jpeg",
    "scheme": "qronos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "buildNumber": "8",
      "bundleIdentifier": "com.sebas.qronos",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 8,
      "package": "com.sebas.qronos",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ICONONewQronnos.jpeg",
        "backgroundColor": "#090a0c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Se utilizará para que los perfiles de empresa puedan escanear códigos QR de clientes.",
          "microphonePermission": "Permite $(PRODUCT_NAME) grabar audio al capturar videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Se utilizará para que los perfiles de empresa puedan subir imágenes de su tienda o empresa."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/QronnosIcon.png",
          "resizeMode": "contain",
          "backgroundColor": "#090a0c",
          "dark": {
            "image": "./assets/images/QronnosIcon.png",
            "backgroundColor": "#090a0c"
          }
        }
      ],
      "expo-font",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Permita usar Face ID por Qronos para mayor seguridad."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60bafa47-7ad8-4d14-b6c8-9b05333a55f7"
      }
    },
    "owner": "qronos"
  }
}